# ══════════════════════════════════════════════
# ENGIPILOT — Configuration Environnement
# Copier en .env et personnaliser AVANT make dev
# Ne JAMAIS commiter le fichier .env
# ══════════════════════════════════════════════

# ── PostgreSQL 17 ──────────────────────────
POSTGRES_DB=engipilot
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme_fort_16chars!

# ── Redis 7 ────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis!

# ── JWT (OBLIGATOIRE — min 48 chars) ───────
# Générer : openssl rand -base64 48
JWT_SECRET=changeme_jwt_secret_min_48_chars_use_openssl_rand_base64_48!
JWT_EXPIRATION_MS=86400000

# ── Kafka ──────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MinIO ──────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio!

# ── Spring Boot ────────────────────────────
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ── Frontend Next.js 15 ────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_IA_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_TELEMETRY_DISABLED=1

# ── IA Service Python ──────────────────────
IA_PORT=8001
IA_DEBUG=true

# ── Grafana ────────────────────────────────
GRAFANA_PASSWORD=admin
