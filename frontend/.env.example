# ═══════════════════════════════════════════════════════════════
#  ENGIPILOT Frontend — Environment Variables
#  Copiez ce fichier en .env.local et configurez les valeurs
# ═══════════════════════════════════════════════════════════════

# ── Base de données (PostgreSQL) ──────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/engipilot?schema=public"

# Pour Supabase/Neon (serverless) — utilise DIRECT_URL pour les migrations
# DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@localhost:5432/engipilot?schema=public"

# ── Auth ─────────────────────────────────────────────────────
NEXTAUTH_SECRET=your_nextauth_secret_minimum_32_chars_change_me
NEXTAUTH_URL=http://localhost:3000

# JWT (utilisé par les API routes Next.js)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters
JWT_EXPIRES_IN=24h

# ── Intelligence IA ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Storage (optionnel) ───────────────────────────────────────
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET=engipilot-documents

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ENGIPILOT
NODE_ENV=development
