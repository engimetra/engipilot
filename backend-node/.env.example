# ═══════════════════════════════════════════════════════════════
#  ENGIPILOT — Environment Variables
#  Copiez ce fichier en .env et remplissez les valeurs
# ═══════════════════════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database (MySQL)
DATABASE_URL="mysql://root:password@localhost:3306/engipilot"

# JWT
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_change_me
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_key_minimum_32_characters
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# OpenAI (Intelligence IA)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Upload / Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
